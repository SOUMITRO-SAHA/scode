# API keys are stored in ~/.scode/auth.json:
# {
#   "claude":    { "apiKey": "sk-ant-..." },
#   "gemini":    { "apiKey": "AIza..." },
#   "deepseek":  { "apiKey": "sk-..." },
#   "zai":       { "apiKey": "..." },
#   "minimax":   { "apiKey": "..." },
#   "cohere":    { "apiKey": "..." }
# }
#
# Environment variable fallbacks (used if auth.json is missing the key):
# ANTHROPIC_API_KEY, GEMINI_API_KEY, DEEPSEEK_API_KEY,
# ZHIPU_API_KEY, MINIMAX_API_KEY, COHERE_API_KEY
