# API keys are stored in ~/.scode/auth.json:
# {
#   "claude":      { "apiKey": "sk-ant-..." },
#   "gemini":      { "apiKey": "AIza..." },
#   "deepseek":    { "apiKey": "sk-..." },
#   "zai":              { "apiKey": "..." },
#   "zai-coding-plan":  { "apiKey": "..." },  # Uses same key as zai
#   "minimax":     { "apiKey": "..." },
#   "commandcode": { "apiKey": "..." },
#   "openai":      { "apiKey": "sk-..." }
# }
#
# Environment variable fallbacks (used if auth.json is missing the key):
# ANTHROPIC_API_KEY, GEMINI_API_KEY, DEEPSEEK_API_KEY,
# ZHIPU_API_KEY, MINIMAX_API_KEY, COMMANDCODE_API_KEY, OPENAI_API_KEY
