{
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "trailingComma": "all",
  "bracketSpacing": true,
  "singleQuote": false,
  "plugins": ["@trivago/prettier-plugin-sort-imports"],
  "importOrder": [
    "^react$",
    "^next.*",
    "^vite.*",
    "<THIRD_PARTY_MODULES>",
    "^[.~/]",
    "^[.@/]",
    "^[./]",
    "^~/(.*)$",
    "^@/(.*)$",
    "^[./]"
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true,
  "overrides": [
    {
      "files": ["*.md", "*.txt"],
      "options": {
        "parser": "markdown"
      }
    }
  ]
}
