{
  "name": "scode",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "cli": "pnpm exec tsx apps/cli/src/index.ts",
    "server": "pnpm exec tsx apps/server/src/index.ts --port=4100",
    "dev:cli": "pnpm --filter @scode/cli dev",
    "dev:server": "pnpm --filter @scode/server dev",
    "demo": "pnpm cli --prompt 'Hello, what can you do?'"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "tsx": "^4.7.1",
    "turbo": "^2.9.18",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
