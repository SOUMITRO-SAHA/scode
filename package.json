{
  "name": "scode",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm cli",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "cli": "bun apps/cli/src/index.tsx 2>/dev/null || pnpm exec tsx apps/cli/src/index.tsx",
    "server": "pnpm exec tsx apps/server/src/index.ts --port=4100",
    "web": "pnpm --filter web dev",
    "dev:cli": "pnpm exec tsx watch apps/cli/src/index.tsx",
    "dev:server": "pnpm --filter @scode/server dev",
    "dev:web": "pnpm --filter web dev",
    "demo": "pnpm cli --prompt 'Hello, what can you do?'",
    "prepare": "husky"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.7.4",
    "tsx": "^4.7.1",
    "turbo": "^2.9.18",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "prettier --write"
    ],
    "*.{md,json,yaml,yml,css,html}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.5.0",
  "engines": {
    "node": ">=18"
  }
}
