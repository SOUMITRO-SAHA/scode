{
  "name": "scode",
  "author": "SOUMITRA SAHA <soumitrosahaofficial@gmail.com>",
  "private": true,
  "scripts": {
    "dev": "SCODE_DEBUG=1 bun apps/cli/src/index.tsx",
    "build": "turbo run build",
    "build:cli": "tsx apps/cli/script/build.ts",
    "build:server": "tsx apps/server/script/build.ts",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "cli": "bun apps/cli/src/index.tsx 2>/dev/null || pnpm exec tsx --tsconfig apps/cli/tsconfig.json apps/cli/src/index.tsx",
    "server": "pnpm exec tsx apps/server/src/index.ts --port=4100",
    "web": "pnpm --filter web dev",
    "dev:headless": "pnpm exec tsx --tsconfig apps/cli/tsconfig.json apps/cli/src/index.tsx --repl",
    "dev:cli": "SCODE_DEBUG=1 bun scripts/dev-cli.ts",
    "dev:server": "SCODE_DEBUG=1 pnpm --filter @scode/server dev",
    "dev:web": "pnpm --filter web dev",
    "demo": "SCODE_DEBUG=1 pnpm exec tsx --tsconfig apps/cli/tsconfig.json apps/cli/src/index.tsx --prompt 'Hello, what can you do?'",
    "prepare": "husky && effect-language-service patch"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "postject": "1.0.0-alpha.6",
    "prettier": "^3.7.4",
    "tsx": "^4.7.1",
    "turbo": "^2.9.18",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "prettier --write"
    ],
    "*.{md,json,yaml,yml,css,html}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.5.0",
  "engines": {
    "node": ">=18",
    "bun": ">=1.3.14"
  },
  "dependencies": {
    "esbuild": "^0.28.1"
  }
}
