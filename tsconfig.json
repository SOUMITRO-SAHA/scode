{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["node"],
    "lib": ["ESNext"],
    "noEmit": true
  },
  "include": ["scripts"],
  "exclude": ["node_modules"]
}
